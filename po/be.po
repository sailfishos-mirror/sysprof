#: src/sysprof-cli/sysprof-cli.c:385
msgid ""
"\n"
"Examples:\n"
"\n"
"  # Record gtk4-widget-factory using trace-fd to get application provided\n"
"  # data as well as GTK and GNOME Shell data providers\n"
"  sysprof-cli --gtk --gnome-shell --use-trace-fd -- gtk4-widget-factory\n"
"\n"
"  # Merge multiple syscap files into one\n"
"  sysprof-cli --merge a.syscap b.syscap > c.syscap\n"
"\n"
"  # Unwind by capturing stack/register contents instead of frame-pointers\n"
"  # where the stack-size is a multiple of page-size\n"
"  sysprof-cli --stack-size=8192\n"
msgstr ""
"\n"
"Прыклады:\n"
"\n"
"  # Запісаць gtk4-widget-factory праз trace-fd, каб атрымаць даныя\n"
"  # ад праграмы, а таксама даных GTK і GNOME Shell\n"
"  sysprof-cli --gtk --gnome-shell --use-trace-fd -- gtk4-widget-factory\n"
"\n"
"  # Аб'яднанне некалькіх файлаў Syscap у адзін\n"
"  sysprof-cli --merge a.syscap b.syscap > c.syscap\n"
"\n"
"  # Разгарнуць праз захоп змесціва стэка/рэгістра, замест адрасоў кадраў,\n"
"  # дзе памер стэка (stack-size) кратны памеру старонкі (page-size)\n"
"  sysprof-cli --stack-size=8192\n"

